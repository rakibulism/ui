{
  "name": "rakibulism-ui",
  "version": "0.6.2",
  "description": "Code-first React design system: 23 accessible, type-safe components with Tailwind-sourced design tokens. Tree-shakeable ESM+CJS, themeable via CSS variables, zero styling dependencies.",
  "author": "Rakibul Islam",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rakibulism-ui": "./bin/rakibulism-ui.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/styles/globals.css",
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.cjs"
    }
  },
  "files": [
    "dist",
    "bin",
    "src/components",
    "src/tokens",
    "src/styles"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "site:dev": "vite --config vite.site.config.ts",
    "site:build": "vite build --config vite.site.config.ts",
    "site:preview": "vite preview --config vite.site.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run type-check && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rakibulism/ui.git"
  },
  "bugs": {
    "url": "https://github.com/rakibulism/ui/issues"
  },
  "homepage": "https://ui-rakibulism.vercel.app",
  "keywords": [
    "ui",
    "design-system",
    "components",
    "component-library",
    "react",
    "react-components",
    "typescript",
    "design-tokens",
    "css-modules",
    "css-variables",
    "accessible",
    "a11y",
    "themeable",
    "tailwind-colors",
    "button",
    "input",
    "modal",
    "toast",
    "tabs",
    "tooltip"
  ],
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.0.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vite-plugin-lib-inject-css": "^2.1.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-tabs": "^1.1.17",
    "clsx": "^2.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
