{
  "name": "rakibulism-ui",
  "version": "0.1.7",
  "description": "Code-first design system and UI components by Rakibul Islam",
  "author": "Rakibul Islam",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/styles/globals.css",
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "site:dev": "vite --config vite.site.config.ts",
    "site:build": "vite build --config vite.site.config.ts",
    "site:preview": "vite preview --config vite.site.config.ts",
    "prepublishOnly": "npm run type-check && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rakibulism/ui.git"
  },
  "bugs": {
    "url": "https://github.com/rakibulism/ui/issues"
  },
  "homepage": "https://github.com/rakibulism/ui#readme",
  "keywords": [
    "ui",
    "design-system",
    "components",
    "react",
    "typescript"
  ],
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.0.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vite-plugin-lib-inject-css": "^2.1.1"
  },
  "dependencies": {
    "clsx": "^2.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
